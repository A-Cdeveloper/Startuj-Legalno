{
  "name": "startuj-legalno",
  "version": "1.0.0",
  "description": "Startuj Legalno",
  "scripts": {
    "watch:css": "sass --watch --quiet-deps scss/style.scss:style.min.css --style compressed",
    "watch:bootstrap": "sass --watch --quiet-deps --load-path=node_modules scss/bootstrap.scss:bootstrap.min.css --style compressed",
    "watch": "npm-run-all --parallel watch:css watch:bootstrap",
    "watch:sass": "npm run watch",
    "build:css": "sass --quiet-deps scss/style.scss:style.min.css --style compressed",
    "build:bootstrap": "sass --load-path=node_modules --quiet-deps scss/bootstrap.scss:bootstrap.min.css --style compressed",
    "build": "npm-run-all build:css build:bootstrap"
  },
  "author": "E-SEO TEAM",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concat": "^1.0.3",
    "npm-run-all": "^4.1.5",
    "postcss-cli": "^11.0.1"
  },
  "dependencies": {
    "animate.css": "^4.1.1",
    "bootstrap": "^5.3.7",
    "sass": "^1.89.2"
  }
}
